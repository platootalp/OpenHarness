---
import { getCollection, render } from 'astro:content';
import DocLayout from '../../layouts/DocLayout.astro';
import ImageGenIsland from '../../components/ImageGenIsland.tsx';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((doc) => {
    let slug: string;
    if (doc.id === 'index.md') {
      slug = 'index';
    } else {
      slug = doc.id.replace(/\.md$/, '');
    }

    return {
      params: { slug },
           props: { doc, slug },
    };
  });
}

const { doc, slug } = Astro.props;
const { Content } = await render(doc);
const currentPath = slug ? `/docs/${slug}/` : '/docs/';
---

<DocLayout
  title={doc.data.title || (slug ? slug.split('/').pop() : '首页')}
  description={doc.data.description}
  currentPath={currentPath}
>
  <div class="prose prose-slate dark:prose-invert max-w-none
    prose-headings:font-semibold prose-headings:text-[var(--color-text)] dark:prose-headings:text-[var(--color-text)]
    prose-headings:font-['JetBrains_Mono']
    prose-a:text-[var(--color-cta)] dark:prose-a:text-[var(--color-cta)] prose-a:no-underline hover:prose-a:underline
    prose-code:text-[var(--color-cta)] dark:prose-code:text-[var(--color-cta)]
    prose-pre:bg-[var(--color-code-bg)] dark:prose-pre:bg-[var(--color-code-bg)]
    prose-img:rounded-lg
    prose-strong:text-[var(--color-text)] dark:prose-strong:text-[var(--color-text)]
    prose-p:text-[var(--color-text)] dark:prose-p:text-[var(--color-text)]
  ">
    <Content components={{ ImageGenIsland: ImageGenIsland as any }} />
  </div>
</DocLayout>
