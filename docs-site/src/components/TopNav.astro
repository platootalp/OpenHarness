---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<header class="fixed top-4 left-4 right-4 z-50 h-14 bg-[var(--color-bg)]/95 backdrop-blur-md border border-[var(--color-border)] rounded-xl navbar-gradient-border animate-fade-in-down shadow-[var(--shadow-md)] transition-all duration-200">
  <div class="flex items-center justify-between w-full max-w-[1400px] mx-auto">
    <div class="flex items-center gap-3">
      <!-- Mobile sidebar toggle -->
      <button
        id="sidebar-toggle"
        type="button"
        class="p-2 rounded-lg hover:bg-[var(--color-hover-bg)] dark:hover:bg-[var(--color-hover-bg)] transition-all duration-200 text-[var(--color-secondary)] hover:text-[var(--color-text)] lg:hidden focus:ring-2 focus:ring-[var(--gradient-primary-start)] focus:ring-offset-2"
        aria-label="Toggle sidebar"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
      <!-- Desktop sidebar collapse -->
      <button
        id="sidebar-collapse"
        type="button"
        class="p-2 rounded-lg hover:bg-[var(--color-hover-bg)] dark:hover:bg-[var(--color-hover-bg)] transition-all duration-200 text-[var(--color-secondary)] hover:text-[var(--color-text)] hidden lg:flex items-center justify-center focus:ring-2 focus:ring-[var(--gradient-primary-start)] focus:ring-offset-2"
        aria-label="Collapse sidebar"
        aria-expanded="false"
      >
        <svg id="collapse-icon-open" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="9" y1="3" x2="9" y2="21"></line>
        </svg>
        <svg id="collapse-icon-closed" class="hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="15" y1="3" x2="15" y2="12"></line>
          <line x1="9" y1="12" x2="9" y2="21"></line>
        </svg>
      </button>
      <a href="/docs/" class="flex items-center gap-2 no-underline hover:opacity-80 transition-opacity">
        <div class="w-8 h-8 rounded text-white font-bold text-sm shadow-[var(--shadow-sm)]" style="background: var(--gradient-primary)">OH</div>
        <span class="font-semibold text-[var(--color-text)] hidden sm:inline font-['JetBrains_Mono']">OpenHarness</span>
        <span class="text-[var(--color-border)] hidden sm:inline">/</span>
        <span class="text-[var(--color-secondary)] text-sm hidden sm:inline">{title}</span>
      </a>
    </div>
    <nav class="flex items-center gap-3">
      <a href="/docs/" class="nav-link text-sm text-[var(--color-secondary)] hover:text-[var(--gradient-primary-start)] transition-all duration-200 hidden md:inline focus:ring-2 focus:ring-[var(--gradient-primary-start)] focus:ring-offset-2 rounded-md px-2 py-1">Home</a>
      <a href="/docs/user/getting-started/" class="nav-link text-sm text-[var(--color-secondary)] hover:text-[var(--gradient-primary-start)] transition-all duration-200 hidden md:inline focus:ring-2 focus:ring-[var(--gradient-primary-start)] focus:ring-offset-2 rounded-md px-2 py-1">User Guide</a>
      <a href="/docs/dev/architecture-overview/" class="nav-link text-sm text-[var(--color-secondary)] hover:text-[var(--gradient-primary-start)] transition-all duration-200 hidden md:inline focus:ring-2 focus:ring-[var(--gradient-primary-start)] focus:ring-offset-2 rounded-md px-2 py-1">Dev Docs</a>
      <div class="w-px h-5 bg-[var(--color-border)] hidden md:block"></div>
      <button
        id="theme-toggle-btn"
        type="button"
        class="p-2 rounded-lg hover:bg-[var(--color-hover-bg)] dark:hover:bg-[var(--color-hover-bg)] transition-all duration-200"
        aria-label="Switch theme"
        title="system"
      >
        <span class="theme-icon" style="color: var(--gradient-primary-start)">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="17"/>
          </svg>
        </span>
      </button>
    </nav>
  </div>
</header>
